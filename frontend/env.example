# ===========================================
# FRONTEND ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: All frontend env vars MUST start with VITE_

# ----- API Configuration -----
VITE_API_URL=http://localhost:4000/api

# ----- Razorpay Payment Gateway -----
# Get from: https://dashboard.razorpay.com/ (Test Mode)
# Use the same Key ID as in backend .env
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# ----- Cloudinary Image Upload -----
# Required for sellers to upload book images
# Get from: https://cloudinary.com/console
# 1. Sign up at cloudinary.com
# 2. Go to Dashboard → Copy "Cloud Name"
# 3. Go to Settings → Upload → Create "Unsigned Upload Preset"
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset

# ----- Deprecated (now using Razorpay) -----
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
